rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email in [
          "olegivanchik1234@gmail.com",
          "rad202331@gmail.com"
        ];
    }

    function isImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function isValidObjectImage() {
      return isImage()
        && request.resource.size < 10 * 1024 * 1024;
    }

    /*
      НОВИЙ ПРАВИЛЬНИЙ ШЛЯХ:
      objects/{userId}/{fileName}
    */
    match /objects/{userId}/{fileName} {
      allow read: if true;

      allow create, update: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && isValidObjectImage()
        );

      allow delete: if isAdmin();
    }

    /*
      СТАРИЙ МОЖЛИВИЙ ШЛЯХ:
      objects/{fileName}
      Залишаємо тільки для адміна, якщо десь старий код ще так вантажить.
    */
    match /objects/{fileName} {
      allow read: if true;

      allow create, update: if isAdmin()
        && isValidObjectImage();

      allow delete: if isAdmin();
    }

    /*
      АВАТАРИ
    */
    match /avatars/{userId}/{fileName} {
      allow read: if true;

      allow create, update: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && request.resource != null
          && request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        );

      allow delete: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == userId
        );
    }

    /*
      ВСЕ ІНШЕ ЗАБОРОНЕНО
    */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
